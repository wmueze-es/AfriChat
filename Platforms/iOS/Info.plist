<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>UIDeviceFamily</key>
    <array><integer>1</integer><integer>2</integer></array>
    <key>UIRequiredDeviceCapabilities</key>
    <array><string>arm64</string></array>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>XSAppIconAssets</key>
    <string>Assets.xcassets/appicon.appiconset</string>
    <key>CFBundleDisplayName</key>
    <string>AfriChat</string>
    <key>CFBundleIdentifier</key>
    <string>com.africhat.app</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>

    <!-- Permission descriptions -->
    <key>NSCameraUsageDescription</key>
    <string>AfriChat uses your camera to share photos in chats and scan QR codes for payments.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>AfriChat accesses your photos to share product images and attachments in chats.</string>
    <key>NSContactsUsageDescription</key>
    <string>AfriChat uses contacts to help you find and message people you know.</string>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>AfriChat uses your location to show nearby border crossings and alerts relevant to your route.</string>
    <key>NSFaceIDUsageDescription</key>
    <string>AfriChat uses Face ID to securely authorise payments via AfriPay.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>AfriChat uses the microphone to record and send voice messages.</string>

    <!-- Push notifications -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
        <string>fetch</string>
    </array>

    <!-- Deep links -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array><string>africhat</string></array>
        </dict>
    </array>
</dict>
</plist>
