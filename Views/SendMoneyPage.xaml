<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AfriChat.ViewModels"
             x:Class="AfriChat.Views.SendMoneyPage"
             x:DataType="vm:SendMoneyViewModel"
             Title="Send Money">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- AfriPay Header -->
            <Frame BackgroundColor="{StaticResource AfriGreen}" CornerRadius="16"
                   Padding="20,16" HasShadow="False" BorderColor="Transparent">
                <VerticalStackLayout Spacing="6">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="💸" FontSize="24" />
                        <Label Text="AfriPay" FontFamily="PoppinsSemiBold" FontSize="20" TextColor="White" />
                    </HorizontalStackLayout>
                    <Label Text="Cross-border money transfer" FontSize="13" TextColor="#B7DCE2" />
                    <Label Text="0.5% fee · Instant · 9 currencies" FontSize="12" TextColor="#ECE6DB" />
                </VerticalStackLayout>
            </Frame>

            <!-- Recipient -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Send to" Style="{StaticResource TitleStyle}" />
                <Frame BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                       BorderColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                       CornerRadius="12" Padding="14,10" HasShadow="False">
                    <Entry Placeholder="Phone number or AfriChat ID (@username)"
                           Text="{Binding RecipientName}" />
                </Frame>
            </VerticalStackLayout>

            <!-- Amount + Currency -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Amount" Style="{StaticResource TitleStyle}" />
                <Grid ColumnDefinitions="*,120" ColumnSpacing="10">
                    <Frame Grid.Column="0"
                           BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                           BorderColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                           CornerRadius="12" Padding="14,10" HasShadow="False">
                        <Entry Placeholder="0.00" Keyboard="Numeric" FontSize="22"
                               FontFamily="PoppinsSemiBold" Text="{Binding Amount}" />
                    </Frame>
                    <Frame Grid.Column="1"
                           BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                           BorderColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                           CornerRadius="12" Padding="10,10" HasShadow="False">
                        <Picker ItemsSource="{Binding Currencies}"
                                ItemDisplayBinding="{Binding Display}"
                                SelectedItem="{Binding SelectedCurrency}" />
                    </Frame>
                </Grid>
            </VerticalStackLayout>

            <!-- Fee Estimate -->
            <Frame BackgroundColor="{StaticResource AfriGreenLight}"
                   BorderColor="Transparent" CornerRadius="10" Padding="14,10" HasShadow="False">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Estimated fee (0.5%)"
                           FontSize="13" TextColor="{StaticResource AfriGreenDark}" />
                    <Label Grid.Column="1" Text="{Binding EstimatedFee, StringFormat='{0:N2}'}"
                           FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource AfriGreenDark}" />
                </Grid>
            </Frame>

            <!-- Note -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Note (optional)" Style="{StaticResource TitleStyle}" />
                <Frame BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                       BorderColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                       CornerRadius="12" Padding="14,8" HasShadow="False">
                    <Entry Placeholder="e.g. Payment for maize, Invoice #102"
                           Text="{Binding Note}" />
                </Frame>
            </VerticalStackLayout>

            <!-- Security Note -->
            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="🔒" FontSize="14" />
                <Label Text="Secured by AfriChat E2E encryption" FontSize="12"
                       TextColor="{StaticResource Gray500}" />
            </HorizontalStackLayout>

            <Button Text="Send Money Securely" Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SendCommand}" IsEnabled="{Binding IsNotBusy}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource AfriGreen}" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
