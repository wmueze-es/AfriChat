<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AfriChat.ViewModels"
             xmlns:models="clr-namespace:AfriChat.Models"
             x:Class="AfriChat.Views.MarketplacePage"
             x:DataType="vm:MarketplaceViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,56,16,12" ColumnDefinitions="*,Auto"
              BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
            <BoxView Grid.ColumnSpan="2" HeightRequest="0.5" VerticalOptions="End"
                     Color="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />
            <VerticalStackLayout>
                <Label Text="Marketplace" Style="{StaticResource HeadlineStyle}" />
                <Label Text="Pan-African trade &amp; products" Style="{StaticResource CaptionStyle}" />
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="+ List" Style="{StaticResource PrimaryButtonStyle}"
                    HeightRequest="36" FontSize="13" Padding="12,0"
                    Command="{Binding PostListingCommand}" />
        </Grid>

        <!-- Tab toggle -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="16,10,16,0">
            <Button Grid.Column="0" Text="🛒 Products"
                    BackgroundColor="{Binding ShowProducts, Converter={StaticResource BoolToColorConverter}, ConverterParameter='green'}"
                    TextColor="{Binding ShowProducts, Converter={StaticResource BoolToColorConverter}, ConverterParameter='text'}"
                    CornerRadius="10" HeightRequest="38" FontSize="13"
                    Command="{Binding ToggleViewCommand}" />
            <Button Grid.Column="1" Text="📈 Trade Opportunities"
                    BackgroundColor="{Binding ShowProducts, Converter={StaticResource BoolToColorConverter}, ConverterParameter='invgreen'}"
                    TextColor="{Binding ShowProducts, Converter={StaticResource BoolToColorConverter}, ConverterParameter='invtext'}"
                    CornerRadius="10" HeightRequest="38" FontSize="13"
                    Command="{Binding ToggleViewCommand}" />
        </Grid>

        <!-- Products Grid -->
        <RefreshView Grid.Row="2" Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy}"
                     IsVisible="{Binding ShowProducts}">
            <CollectionView ItemsSource="{Binding Products}" Margin="12,10,12,0"
                           ItemsLayout="VerticalGrid, 2">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ProductListing">
                        <Frame Margin="4" CornerRadius="14" Padding="0" HasShadow="False"
                               BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource CardBackgroundDark}}"
                               BorderColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MarketplaceViewModel}}, Path=OpenProductCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout>
                                <!-- Product Image Area -->
                                <Frame BackgroundColor="{StaticResource AfriGreenLight}"
                                       HeightRequest="110" CornerRadius="0" HasShadow="False"
                                       BorderColor="Transparent" Padding="0" IsClippedToBounds="True">
                                    <Label Text="{Binding Emoji}" FontSize="48"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Frame>
                                <VerticalStackLayout Padding="10,8" Spacing="3">
                                    <Label Text="{Binding CategoryDisplay}" FontSize="10"
                                           TextColor="{StaticResource AfriGreenMid}" FontFamily="PoppinsMedium" />
                                    <Label Text="{Binding Title}" FontFamily="PoppinsMedium" FontSize="13"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                           MaxLines="2" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding PriceDisplay}" FontFamily="PoppinsSemiBold" FontSize="14"
                                           TextColor="{StaticResource AfriGreen}" />
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="📍" FontSize="11" />
                                        <Label Text="{Binding Location}" FontSize="11" TextColor="{StaticResource Gray400}"
                                               LineBreakMode="TailTruncation" MaxLines="1" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Trade Opportunities List -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding Opportunities}"
                        Margin="16,10,16,0"
                        IsVisible="{Binding ShowProducts, Converter={StaticResource InverseBoolConverter}}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:TradeOpportunity">
                    <Frame Margin="0,0,0,10" CornerRadius="14" Padding="14" HasShadow="False"
                           BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource CardBackgroundDark}}"
                           BorderColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}">
                        <VerticalStackLayout Spacing="6">
                            <HorizontalStackLayout Spacing="8">
                                <Frame BackgroundColor="{StaticResource AfriBluLight}" BorderColor="Transparent"
                                       CornerRadius="8" Padding="6,3" HasShadow="False">
                                    <Label Text="{Binding TypeDisplay}" FontSize="11"
                                           TextColor="{StaticResource AfriBlue}" FontFamily="PoppinsMedium" />
                                </Frame>
                                <Frame BackgroundColor="{StaticResource AfriGreenLight}" BorderColor="Transparent"
                                       CornerRadius="8" Padding="6,3" HasShadow="False">
                                    <Label Text="{Binding Sector}" FontSize="11"
                                           TextColor="{StaticResource AfriGreenDark}" FontFamily="PoppinsMedium" />
                                </Frame>
                            </HorizontalStackLayout>
                            <Label Text="{Binding Title}" FontFamily="PoppinsSemiBold" FontSize="15"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                            <Label Text="{Binding Description}" FontSize="13"
                                   TextColor="{StaticResource Gray500}" MaxLines="3" LineBreakMode="TailTruncation" />
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="📍" FontSize="12" />
                                <Label Text="{Binding PosterCountry}" FontSize="12" TextColor="{StaticResource Gray400}" />
                                <Label Text="·" TextColor="{StaticResource Gray400}" />
                                <Label Text="{Binding PosterName}" FontSize="12" TextColor="{StaticResource Gray500}" />
                            </HorizontalStackLayout>
                            <Button Text="Express interest →" Style="{StaticResource OutlineButtonStyle}"
                                    HorizontalOptions="Start" Padding="14,0" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
